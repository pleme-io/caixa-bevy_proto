   :body "(\n  name: \"Left\",\n  schematics: {\n    \"bevy_proto::custom::NodeBundle\": (\n      style: (\n        width: Px(200.0),\n        border: (\n          left: Px(2.0),\n          right: Px(2.0),\n          top: Px(2.0),\n          bottom: Px(2.0),\n        ),\n      ),\n      background_color: (Rgba(\n        red: 0.65,\n        green: 0.65,\n        blue: 0.65,\n        alpha: 1.0\n      )),\n    )\n  },\n  children: [(\n    value: Inline((\n      name: \"Left-Content\",\n      schematics: {\n        \"bevy_proto::custom::NodeBundle\": (\n          style: (\n            width: Percent(100.0),\n          ),\n          background_color: (Rgba(\n            red: 0.15,\n            green: 0.15,\n            blue: 0.15,\n            alpha: 1.0\n          )),\n        )\n      },\n      children: [(\n        value: Inline((\n          name: \"Left-Content-Text\",\n          schematics: {\n            \"bevy_proto::custom::TextBundle\": (\n              style: (\n                margin: (\n                  left: Px(5.0),\n                  right: Px(5.0),\n                  top: Px(5.0),\n                  bottom: Px(5.0),\n                ),\n              ),\n              text: (\n                sections: [(\n                  value: \"Text Example\",\n                  style: (\n                    font: AssetPath(\"fonts/JetBrainsMono-Regular.ttf\"),\n                    font_size: 30.0,\n                    color: White,\n                  )\n                )]\n              ),\n            ),\n            \"bevy_ui::widget::label::Label\": ()\n          }\n        ))\n      )]\n    ))\n  )]\n)"} {:path "assets/examples/bevy/ui/Blue.prototype.ron"
