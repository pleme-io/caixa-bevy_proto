   :body "(\n  name: \"Light\",\n  schematics: {\n    \"bevy_proto::custom::PointLightBundle\": (\n      transform: (\n        translation: (\n          x: 4.0,\n          y: 5.0,\n          z: 4.0\n        ),\n      )\n    )\n  }\n)"} {:path "assets/examples/bevy/asset_loading/Cube.prototype.ron"
   :sha256 "d7bf055467030ec7c8b4dd85a8eea2da6707a66d87073d4475ddc819a5e87e9a"
   :size 730
   :body "(\n  name: \"Cube\",\n  schematics: {\n    \"bevy_proto::custom::MaterialMeshBundle<bevy_pbr::pbr_material::StandardMaterial>\": (\n      // Mesh is an `AssetSchematic` which has a dedicated `MeshInput` type used for\n      // defining the mesh within a prototype file.\n      // The `MeshInput` type is an enum with various variants for primitive shapes.\n      // Here, we're using the `Cube` variant:\n      mesh: Asset(Cube((\n        size: 2.0,\n      ))),\n      material: Asset((\n        base_color: Rgba(\n          red: 0.8,\n          green: 0.7,\n          blue: 0.6,\n          alpha: 1.0\n        ),\n      )),\n      transform: (\n        translation: (\n          x: 0.0,\n          y: 0.0,\n          z: 0.0\n        )\n      ),\n    )\n  },\n)\n"} {:path "assets/examples/bevy/asset_loading/Sphere.prototype.ron"
   :sha256 "019fe0b0c5fc26c5a5a327efcbbdcd8e6fb059a43ec43fe1b83917463f589df8"
   :size 737
   :body "(\n  name: \"Sphere\",\n  schematics: {\n    \"bevy_proto::custom::MaterialMeshBundle<bevy_pbr::pbr_material::StandardMaterial>\": (\n      // Mesh is an `AssetSchematic` which has a dedicated `MeshInput` type used for\n      // defining the mesh within a prototype file.\n      // The `MeshInput` type is an enum with various variants for primitive shapes.\n      // Here, we're using the `Cube` variant:\n      mesh: Asset(UvSphere((\n        radius: 1.0,\n      ))),\n      material: Asset((\n        base_color: Rgba(\n          red: 0.8,\n          green: 0.7,\n          blue: 0.6,\n          alpha: 1.0\n        ),\n      )),\n      transform: (\n        translation: (\n          x: 3.0,\n          y: 0.0,\n          z: 0.0\n        )\n      ),\n    )\n  }\n)\n"} {:path "assets/examples/bevy/sprite_sheet/Player.prototype.ron"
   :sha256 "3ef1653d6177fb54980351cfdf6189d83f13e7d6fab4243c306f12cb4efe290a"
   :size 1095
   :body "(\n  name: \"Player\",\n  schematics: {\n    \"bevy_proto::custom::SpriteSheetBundle\": (\n      // The schematic for `TextureAtlas` defines an enum input with a `Grid` variant.\n      // The fields of this variant map to the parameters of `TextureAtlas::from_grid`.\n      texture_atlas: Asset(Grid(\n        texture: AssetPath(\"textures/rpg/chars/gabe/gabe-idle-run.png\"),\n        tile_size: (\n          x: 24.0,\n          y: 24.0\n        ),\n        columns: 7,\n        rows: 1,\n        padding: None,\n        offset: None,\n      )),\n      sprite: (\n        // Start our sprite at the first frame of the run animation\n        index: 1\n      ),\n      transform: (\n        scale: (\n          x: 6.0,\n          y: 6.0,\n          z: 6.0,\n        )\n      ),\n    ),\n    \"bevy_sprite_sheet::AnimationIndices\": (\n      // The run animation actually starts on the second frame (index 1)\n      first: 1,\n      last: 6\n    ),\n    \"bevy_sprite_sheet::AnimationTimer\": ((\n      duration: (\n        secs: 0,\n        // 1e8 nanoseconds == 0.1 seconds\n        nanos: 100000000\n      ),\n      mode: Repeating\n    ))\n  }\n)"} {:path "assets/examples/custom_loader/Player.custom.yaml"
   :sha256 "634121ea28e1a41682bddde99c2574584cfef75c8365f0998b5c4d9e136e2ff8"
   :size 338
   :body "name: Player\nschematics:\n  custom_loader::Player:\n  # Comment out the `Health` component below to have this prototype\n  # be rejected by our custom loader.\n  custom_loader::Health:\n    - 100\n  # Comment out the `Mana` component below to have a default instance\n  # of it be inserted by our custom loader.\n  custom_loader::Mana:\n    - 100\n"} {:path "assets/examples/basic_schematic/Player.prototype.ron"
   :sha256 "652802b14cb3c8d5c82e3d5f379ae4cbbe68ad3be0a479f4fc218f282ce08660"
   :size 332
   :body "(\n  name: \"Player\",\n  schematics: {\n    \"basic_schematic::Playable\": (),\n    \"basic_schematic::Alignment\": Good,\n    // This schematic is provided by `bevy_proto` and resolves\n    // to a Bevy `SpriteBundle`:\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/player/p1_front.png\"),\n    ),\n  }\n)"} {:path "assets/examples/basic_schematic/PlayerConfig.prototype.ron"
   :sha256 "c1bfa91e805d72285219627c3553206e079d5e40f028539338348a49479ed222"
   :size 216
   :body "(\n  name: \"PlayerConfig\",\n  // Since this prototype only contains a resource,\n  // we can mark it as not needing an entity to be spawned.\n  entity: false,\n  schematics: {\n    \"basic_schematic::MaxPlayers\": (1),\n  }\n)"} {:path "assets/examples/templates/Player.prototype.ron"
   :sha256 "122e1fb9c4cfc53ee04d022d5e0dd7ca9abc942a343a2debf2421e22ecaddcf2"
   :size 1104
   :body "(\n  name: \"Player\",\n  // Templates allow us to inherit functionality from other prototypes.\n  // They are applied in reverse order, so that prototypes closer to\n  // the beginning of the list overwrite ones closer to the end.\n  // This only applies to schematics of the same type in order to\n  // maintain schematic uniqueness.\n  // Other schematics will continue to apply to this prototype as normal.\n  templates: [\n    // Because `Small` comes before `Big`, we can expect the schematics\n    // from `Small` to overwrite those from `Big`.\n    \"Small\",\n    \"Big\",\n    // The strings above are shorthand for paths to prototypes\n    // in the same directory and with the same extension.\n    // We can also use more conventional paths:\n    \"./Green.prototype.ron\",\n    // Prototypes in other formats will need to specify their extension\n    \"./Red.prototype.yaml\",\n  ],\n  // Schematics defined on a prototype always take precedence over those\n  // defined in templates.\n  schematics: {\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/player/p1_front.png\")\n    )\n  }\n)"} {:path "assets/examples/templates/Green.prototype.ron"
   :sha256 "557f7152b2bc96234344ba3bef78cf182e4ddc8da937fec5bf0ca3450bb2708d"
   :size 149
   :body "(\n  name: \"Green\",\n  schematics: {\n    \"templates::Colored\": (Rgba(\n      red: 0.0,\n      green: 1.0,\n      blue: 0.0,\n      alpha: 1.0,\n    ))\n  }\n)"} {:path "assets/examples/templates/Big.prototype.ron"
   :sha256 "bdf58a31652b480c60f4592e5126038abdac422f3624b13508cd8412c0ca229e"
   :size 264
   :body "(\n  name: \"Big\",\n  schematics: {\n    \"templates::Scaled\": (2.5),\n    // This will have no effect since its overwritten by the one on `Player`:\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/player/p2_front.png\")\n    )\n  }\n)"} {:path "assets/examples/templates/Small.prototype.ron"
   :sha256 "aa62191cc501faf5f41e6daf938c7eecdeea95563d87a701926a565d7d8314b4"
   :size 267
   :body "(\n  name: \"Small\",\n  schematics: {\n    \"templates::Scaled\": (0.25),\n    // This will have no effect since its overwritten by the one on `Player`:\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/player/p2_front.png\")\n    )\n  }\n)"} {:path "assets/examples/templates/Red.prototype.yaml"
   :sha256 "c13a525c92d59f32d16e1d1c0737aafec5e796f0f1dbe6cf9a9ad2af30aea63e"
   :size 120
   :body "name: Red\nschematics:\n  templates::Colored:\n    - !Rgba\n      red: 1.0\n      green: 0.0\n      blue: 0.0\n      alpha: 1.0"} {:path "assets/examples/asset_schematic/Level1.prototype.ron"
   :sha256 "841df7c41e68d1f44ac5988b84f1f5dc9552d45dc4629d16754d6df871d7cae8"
   :size 484
   :body "(\n  name: \"Level1\",\n  schematics: {\n    \"asset_schematic::CurrentLevel\": (\n      // The `InlinableProtoAsset::Asset` variant allows us to define our asset inline.\n      level: Asset((\n        name: \"Tutorial\",\n        // Both `InlinableProtoAsset` and the standard `ProtoAsset` contain an `AssetPath`\n        // variant for cases where we want to reference an asset defined in a separate file.\n        player: AssetPath(\"textures/platformer/player/p1_front.png\")\n      ))\n    ),\n  }\n)"} {:path "assets/examples/custom_config/Player.prototype.ron"
   :sha256 "6e74deceb31256df5e8455a560190eb637b6b43ab537a12a139924bebf4781eb"
   :size 20
   :body "(\n  name: \"Player\"\n)"} {:path "assets/examples/custom_schematic/CustomSchematic.prototype.ron"
   :sha256 "45ca415b45ec6795d0fb62b0424c4bc43fbfe391c16183d5b52a72a6fd3f4680"
   :size 287
   :body "(\n  name: \"CustomSchematic\",\n  schematics: {\n    // Notice that even though we used `FooInput` as our input type,\n    // this still uses the base `Foo` type.\n    \"custom_schematic::Foo\": (\n      image: \"textures/platformer/player/p1_front.png\",\n      message: Some(\"Hi mom!\")\n    )\n  }\n)"} {:path "assets/fonts/OFL.txt"
