   :sha256 "39330a4eb48fab172a7cbe79cc0a8e52e64620e44713a3bbc22ed70dd2505ca0"
   :size 578
   :body "(\n  // The name of this prototype.\n  // It must be unique across all loaded prototypes.\n  // In the future, there will be an optional `package` field\n  // to help ensure uniqueness within a \"package\".\n  name: \"Player\",\n  // The unordered mapping of schematics for this prototype.\n  // These are deserialized using the reflection deserializer.\n  schematics: {\n    // This schematic is provided by `bevy_proto` and resolves\n    // to a Bevy `SpriteBundle`:\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/player/p1_front.png\"),\n    ),\n  }\n)"} {:path "assets/examples/hierarchy/HatSalesman.prototype.ron"
   :sha256 "b6cc1001abf3f1781a32705c4f03772eca6289802203c3578a8640ca3686a67f"
   :size 445
   :body "(\n  name: \"HatSalesman\",\n  schematics: {\n    \"hierarchy::HasHat\": ()\n  },\n  children: [\n    // This child will be its own entity\n    \"Hat\",\n    (\n      // This child will merge into the child in `Parent`\n      // with the matchin `merge_key`\n      merge_key: Some(\"hat-wearer\"),\n      value: Inline((\n        name: \"HatSaleschild\",\n        schematics: {\n          \"hierarchy::HasHat\": ()\n        },\n        children: [\"Hat\"]\n      ))\n    )\n  ]\n)"} {:path "assets/examples/hierarchy/Lock.prototype.ron"
   :sha256 "4505983fae9176c7b93a1562599ddbdf8fe673ec9d79d4518c3def771d77567e"
   :size 308
   :body "(\n  name: \"Lock\",\n  schematics: {\n    \"hierarchy::DrawRelations\": (),\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/tiles/lock_yellow.png\"),\n      transform: (\n        translation: (\n          x: -200,\n          y: -200,\n          z: 0\n        )\n      )\n    )\n  },\n)"} {:path "assets/examples/hierarchy/Hat.prototype.ron"
   :sha256 "d06931c86f1d64ed17f2394fa0db5749fc7b11e882746f3c484b3cc8d793fdc3"
   :size 326
   :body "(\n  name: \"Hat\",\n  schematics: {\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/items/mushroomBrown.png\"),\n      // Remember: children are anchored to their parents!\n      transform: (\n        translation: (\n          x: 0,\n          y: 80,\n          z: 0\n        )\n      )\n    )\n  }\n)"} {:path "assets/examples/hierarchy/Child.prototype.ron"
   :sha256 "7bed81abd5065c6287a3717e18686b97fd9e5b577a8a4899e842657973b811f2"
   :size 362
   :body "(\n  name: \"Child\",\n  schematics: {\n    \"hierarchy::DrawRelations\": (),\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/player/p2_front.png\"),\n      // Remember: children are anchored to their parents!\n      transform: (\n        translation: (\n          x: 0,\n          y: -200,\n          z: 0\n        )\n      )\n    )\n  }\n)"} {:path "assets/examples/hierarchy/Parent.prototype.ron"
   :sha256 "74362f53375a282f6a01f46d10f6f4d2bcf4022c3c959cd2c6803ae2f45a8cc4"
   :size 2958
   :body "(\n  name: \"Parent\",\n  // Templates always merge into a single entity.\n  // However, they may define their own children which may or may\n  // not merge into their inheritor's children (see below for details).\n  templates: [\"HatSalesman\"],\n  schematics: {\n    \"bevy_proto::custom::SpriteBundle\": (\n      texture: AssetPath(\"textures/platformer/player/p1_front.png\"),\n      transform: (\n        translation: (\n          x: 0,\n          y: 200,\n          z: 0\n        )\n      )\n    )\n  },\n  children: [\n    // Children can be simple paths to other prototypes\n    \"Lock\",\n    // We can also define some more metadata around our children:\n    (\n      // Merge keys allow child entities from templates to be merged into\n      // a single entity.\n      // Unlike names, these do not need to be globally unique.\n      merge_key: Some(\"hat-wearer\"),\n      // And again, we can use the path to another prototype\n      value: Path(\"Child\")\n    ),\n    // But they can also be nested prototypes by using Inline\n    (\n      value: Inline((\n        // Names must still be globally unique!\n        // (Tip: you can use a random UUID to ensure uniqueness)\n        name: \"OtherChild\",\n        schematics: {\n          \"hierarchy::DrawRelations\": (),\n          \"bevy_proto::custom::SpriteBundle\": (\n            texture: AssetPath(\"textures/platformer/player/p3_front.png\"),\n            transform: (\n              // Remember: children are anchored to their parents!\n              translation: (\n                x: 200,\n                y: -200,\n                z: 0\n              )\n            )\n          )\n        },\n        // And we can nest as much as we want!\n        children: [(\n          value: Inline((\n            name: \"Key\",\n            schematics: {\n              // Using `ProtoEntity::EntityPath` we can reference any other\n              // entity in the tree.\n              // Here, we want to point to the \"Lock\" entity.\n              //\n              // We can do this a couple ways:\n              // 1. \"/Lock\" - Get first \"Lock\" child on root entity\n              // 2. \"../../Lock\" - Get first \"Lock\" child on grandparent\n              // 3. \"../~-1:Lock\" - Get first \"Lock\" sibling before parent\n              //\n              // We'll go with #2 here.\n              // Keep in mind that since `Opens` requires an `Entity`,\n              // this must point to a valid entity or we'll panic!\n              \"hierarchy::Opens\": (EntityPath(\"../../Lock\")),\n              \"hierarchy::DrawRelations\": (),\n              \"bevy_proto::custom::SpriteBundle\": (\n                texture: AssetPath(\"textures/platformer/items/keyYellow.png\"),\n                transform: (\n                  // Remember: children are anchored to their parents!\n                  translation: (\n                    x: 0,\n                    y: -200,\n                    z: 0\n                  )\n                )\n              )\n            },\n          ))\n        )]\n      ))\n    ),\n  ]\n)"} {:path "assets/examples/hot_reload/ReloadableSprite.prototype.ron"
   :sha256 "1fcf41409152b529a2bef2dccd706e5182d7d4ec16d3237bc93ee01ca1f43bdc"
   :size 370
   :body "(\n  name: \"ReloadableSprite\",\n  schematics: {\n    \"bevy_proto::custom::SpriteBundle\": (\n      // This example is all about hot-reloading,\n      // so feel free to change any of these values!\n      texture: AssetPath(\"textures/platformer/player/p1_front.png\"),\n      transform: (\n        translation: (\n          x: 0.0,\n          y: 100.0,\n        )\n      )\n    ),\n  }\n)"} {:path "assets/examples/bevy/ui/Red.prototype.ron"
