mponentType\" : 5126,\n            \"count\" : 2012,\n            \"type\" : \"VEC3\"\n        },\n        {\n            \"bufferView\" : 2,\n            \"componentType\" : 5126,\n            \"count\" : 2012,\n            \"type\" : \"VEC2\"\n        },\n        {\n            \"bufferView\" : 3,\n            \"componentType\" : 5123,\n            \"count\" : 11808,\n            \"type\" : \"SCALAR\"\n        }\n    ],\n    \"bufferViews\" : [\n        {\n            \"buffer\" : 0,\n            \"byteLength\" : 24144,\n            \"byteOffset\" : 0\n        },\n        {\n            \"buffer\" : 0,\n            \"byteLength\" : 24144,\n            \"byteOffset\" : 24144\n        },\n        {\n            \"buffer\" : 0,\n            \"byteLength\" : 16096,\n            \"byteOffset\" : 48288\n        },\n        {\n            \"buffer\" : 0,\n            \"byteLength\" : 23616,\n            \"byteOffset\" : 64384\n        }\n    ],\n    \"buffers\" : [\n        {\n            \"byteLength\" : 88000,\n            \"uri\" : \"data:application/octet-stream;base64,\"\n        }\n    ]\n}\n"} {:path "assets/examples/bevy/asset_loading/Light.prototype.ron"
   :sha256 "71ec3980936e8209170135061ce0e6cf3ea4bd0e4ce01920f2c1f5762b8e2dff"
