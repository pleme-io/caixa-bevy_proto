   :body "pub use plugin::*;\n\npub mod assets;\npub mod children;\npub mod cycles;\npub mod deps;\npub mod impls;\npub mod load;\npub mod path;\npub mod plugin;\npub mod proto;\nmod registration;\npub mod schematics;\npub mod templates;\npub mod tree;\n"} {:path "bevy_proto_backend/src/impls/bevy_impls/core.rs"
   :sha256 "08f5607ec941705e136bea79ec3ca4359c9290100e717ee336b9c0ae4e88fe60"
