om::NodeBundle\": (\n                style: (\n                  width: Percent(100.0),\n                  height: Percent(100.0),\n                  position_type: Absolute,\n                  left: Px(60.0),\n                  bottom: Px(60.0),\n                ),\n                background_color: (Rgba(\n                  red: 1.0,\n                  green: 0.7,\n                  blue: 0.7,\n                  alpha: 1.0\n                )),\n              )\n            }\n          ))\n        ),\n        (\n          value: Inline((\n            name: \"Red-4\",\n            schematics: {\n              \"bevy_proto::custom::NodeBundle\": (\n                style: (\n                  width: Percent(100.0),\n                  height: Percent(100.0),\n                  position_type: Absolute,\n                  left: Px(80.0),\n                  bottom: Px(80.0),\n                ),\n                background_color: (Rgba(\n                  red: 1.0,\n                  green: 0.9,\n                  blue: 0.9,\n                  alpha: 0.4\n                )),\n              )\n            }\n          ))\n        ),\n      ]\n    ))\n  )]\n)"} {:path "assets/examples/bevy/ui/Left.prototype.ron"
   :sha256 "2dd085b7b3ef86fe3691f4c8cb8c104526f3c01762bcb1e4f0d6ea21efb78e7e"
